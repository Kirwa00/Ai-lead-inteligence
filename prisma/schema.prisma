generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  plan        String       @default("free")
  // Prepaid wallet balance in micro-USD (1e-6 USD) of raw Anthropic token budget.
  // The 7x markup is applied at purchase time; the meter debits real token cost.
  creditBalanceMicros BigInt @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  campaigns   Campaign[]
  integrations Integration[]
  logs        ActivityLog[]
  reports     Report[]
  walletTransactions WalletTransaction[]
  usageEvents        UsageEvent[]
  payments           Payment[]
}

// A top-up payment via a provider (Stripe / Flutterwave). Credits the wallet
// (as a WalletTransaction) once the provider confirms success.
model Payment {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId              String?
  provider            String       // "stripe" | "flutterwave"
  providerRef         String       // checkout session id / tx ref
  packageId           String?
  valueMicros         BigInt       // service value to credit on success
  currency            String       @default("USD")
  status              String       @default("pending") // pending | succeeded | failed
  walletTransactionId String?      @unique
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([provider, providerRef]) // idempotency: one credit per provider ref
  @@index([organizationId, createdAt])
}

// Append-only ledger of every credit movement (grant / topup / debit / refund).
model WalletTransaction {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type               String       // grant | topup | debit | refund | adjustment
  amountMicros       BigInt       // signed: positive = credit, negative = debit
  balanceAfterMicros BigInt
  description        String?
  metadata           Json?
  usageEvent         UsageEvent?
  createdAt          DateTime     @default(now())

  @@index([organizationId, createdAt])
}

// One row per billed LLM call — the metering source of truth (tokens, model, cost).
model UsageEvent {
  id                  String             @id @default(cuid())
  organizationId      String
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId              String?
  feature             String             // e.g. "research"
  agentType           String?            // e.g. "research"
  model               String             // e.g. "claude-opus-4-8"
  inputTokens         Int                @default(0)
  outputTokens        Int                @default(0)
  rawCostMicros       BigInt
  walletTransactionId String?            @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])
  createdAt           DateTime           @default(now())

  @@index([organizationId, createdAt])
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  passwordHash   String?
  role           String       @default("member")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Campaign {
  id             String       @id @default(cuid())
  name           String
  goal           String?
  description    String?
  // Free-form product/service/objective context (and any attached doc text)
  // that the AI workforce uses to tailor research & outreach.
  context        String?
  status         String       @default("draft")
  industry       String?
  geography      String?
  companySize    String?
  targetTitles   String[]
  keywords       String[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]
  researchJobs   ResearchJob[]
  workflows      Workflow[]
  emails         Email[]
  reports        Report[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Tracks an async Research Agent run so the UI doesn't block on a ~20s LLM call.
model ResearchJob {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  organizationId String
  status         String    @default("queued") // queued | running | succeeded | failed
  added          Int       @default(0)
  error          String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([campaignId, createdAt])
}

model Company {
  id          String    @id @default(cuid())
  name        String
  domain      String?   @unique
  industry    String?
  size        String?
  country     String?
  city        String?
  description String?
  website     String?
  linkedinUrl String?
  revenue     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[]
  leads       Lead[]
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  title       String?
  email       String?
  emailStatus String?
  phone       String?
  linkedinUrl String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  score       Int      @default(0)
  status      String   @default("uncontacted")
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  activities  LeadActivity[]
  emails      Email[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  note      String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Email {
  id         String   @id @default(cuid())
  subject    String
  body       String
  status     String   @default("draft")
  sentAt     DateTime?
  openedAt   DateTime?
  repliedAt  DateTime?
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AIAgent {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String   @default("idle")
  config      Json?
  tasksTotal  Int      @default(0)
  tasksFailed Int      @default(0)
  tasks       AITask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AITask {
  id          String   @id @default(cuid())
  agentId     String
  agent       AIAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workflowId  String?
  workflow    Workflow? @relation(fields: [workflowId], references: [id])
  type        String
  status      String   @default("pending")
  input       Json?
  output      Json?
  errorMsg    String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model Workflow {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  currentStep Int     @default(0)
  totalSteps  Int     @default(12)
  tasks      AITask[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Report {
  id         String   @id @default(cuid())
  name       String
  type       String
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  // Reconciled with existing Supabase column (holds real data) to avoid a
  // destructive drop during db push.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  data       Json?
  createdAt  DateTime @default(now())
}

model Integration {
  id             String       @id @default(cuid())
  provider       String
  status         String       @default("disconnected")
  config         Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([provider, organizationId])
}

model ActivityLog {
  id             String       @id @default(cuid())
  action         String
  resource       String?
  resourceId     String?
  metadata       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}
